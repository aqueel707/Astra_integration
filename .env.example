# ============================================================
# Astra — environment variables
# ============================================================
# Copy this file to .env for local development.
# On Koyeb, set these via the dashboard: Service → Environment.
# NEVER commit .env to git.
# ============================================================

# ── Database (Supabase Postgres) ─────────────────────────────
# Get this from: Supabase dashboard → Project Settings → Database → URI
# Replace [YOUR-PASSWORD] with your actual DB password.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# ── Firebase Auth ────────────────────────────────────────────
# Get this from: Firebase console → Project settings → General → Project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# Set to "false" for local development without Firebase
# (all requests treated as demo user)
FIREBASE_ENABLED=true

# ── App settings ─────────────────────────────────────────────
APP_ENV=production
DEBUG=false
DB_ECHO=false

# ── Redis (disabled on free Koyeb tier) ──────────────────────
# We drop Redis to fit in 512MB RAM. In-process streaming only.
REDIS_ENABLED=false
